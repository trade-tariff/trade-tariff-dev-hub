<!DOCTYPE html>
<html class="govuk-template app-html-class">

  <%= render partial: 'layouts/page' %>

  <head>
    <title><%= content_for(:title) || "Commodity Code Identification Tool Developer Hub" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag 'favicon.ico', sizes: '48x48' %>
    <%= favicon_link_tag 'favicon.svg', sizes: 'any' %>
    <%= favicon_link_tag 'govuk-icon-mask.svg', rel: 'mask-icon', type: 'image/svg', color: "#0b0c0c" %>
    <%= favicon_link_tag 'govuk-icon-180.png', rel: 'apple-touch-icon', type: 'image/png' %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <header class="govuk-header" data-module="govuk-header">
    <%= yield :header %>
  </header>

  <body class="govuk-template__body app-body-class">
    <%= yield :body %>
  </body>

  <footer class="govuk-footer">
    <%= yield :footer %>
  </footer>
</html>
