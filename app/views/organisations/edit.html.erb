<% content_for :back_link do %><%= govuk_back_link(href: organisation_path(organisation)) %><% end %>
<%= govuk_form_for @organisation do |f| %>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">Updating organisation name</h1>
      <%= f.govuk_text_field :organisation_name,
        width: 'two-thirds',
        label: nil,
        hint: { text: "Supply a changed organisation name." } %>

      <div class="govuk-button-group">
        <%= f.govuk_submit "Continue" %>
        <%= govuk_link_to('Cancel', organisation_path(organisation)) %>
      </div>
    </div>
  </div>
<% end %>
