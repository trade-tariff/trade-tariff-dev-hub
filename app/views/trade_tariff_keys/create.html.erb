<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l">Trade Tariff API key created</h1>

    <%= govuk_warning_text(text: "Copy your client secret now. It will not be shown again once you leave this page.") %>

    <%= govuk_summary_list do |summary_list|
      summary_list.with_row do |row|
        row.with_key(text: "Client ID")
        row.with_value(text: @trade_tariff_key.client_id)
      end
      summary_list.with_row do |row|
        row.with_key(text: "Description")
        row.with_value(text: @trade_tariff_key.description)
      end
      summary_list.with_row do |row|
        row.with_key(text: "Scopes")
        row.with_value(text: @trade_tariff_key.scopes.join(", "))
      end
    end %>

    <h2 class="govuk-heading-m govuk-!-margin-top-6">Client secret</h2>
    <div class="govuk-inset-text govuk-!-margin-bottom-2">
      <code class="govuk-code" id="trade-tariff-client-secret"><%= @client_secret %></code>
    </div>
    <div class="govuk-!-margin-bottom-6">
      <button type="button" class="govuk-button govuk-button--secondary" data-module="govuk-button" data-copy-target="trade-tariff-client-secret" data-copy-button>
        Copy secret
      </button>
    </div>

    <h2 class="govuk-heading-m govuk-!-margin-top-6">How to get an access token</h2>
    <p class="govuk-body">Use the token endpoint below with your client ID and secret to obtain an access token.</p>
    <p class="govuk-body">
      <strong>Token endpoint:</strong>
      <br>
      <code class="govuk-code" id="trade-tariff-token-endpoint"><%= @cognito_token_endpoint %></code>
    </p>
    <p class="govuk-body govuk-!-margin-bottom-2"><strong>Example curl command:</strong></p>
    <pre class="app-code-block govuk-body govuk-!-margin-bottom-2"><code id="trade-tariff-curl-command"><%= trade_tariff_curl_example(@cognito_token_endpoint, @trade_tariff_key.client_id, @client_secret) %></code></pre>
    <div class="govuk-!-margin-bottom-6">
      <button type="button" class="govuk-button govuk-button--secondary" data-module="govuk-button" data-copy-target="trade-tariff-curl-command" data-copy-button>
        Copy curl command
      </button>
    </div>

    <div class="govuk-button-group">
      <%= govuk_button_link_to("Back to Trade Tariff keys", trade_tariff_keys_path) %>
    </div>
  </div>
</div>
