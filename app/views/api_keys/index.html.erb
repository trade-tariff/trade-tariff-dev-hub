<h1 class="govuk-heading-l">Your API keys</h1>
<p class="govuk-body">Manage all API keys that have been generated for your organisation.</p>

<%= govuk_table do |table|
  table.with_head do |head|
    head.with_row do |row|
      row.with_cell(text: 'API key')
      row.with_cell(text: 'Description')
      row.with_cell(text: 'Created on')
      row.with_cell(text: 'Status')
      row.with_cell(text: '')
    end
  end

  table.with_body do |body|
    body.with_row do |row|
      row.with_cell(header: true, text: 'Placeholder 1')
      row.with_cell(text: 'Organisation name')
      row.with_cell(text: 'DateTime')
      row.with_cell(text: 'Status')
      row.with_cell do
        link_to 'Delete', api_keys_path, class: 'govuk-link'
      end
    end

    body.with_row do |row|
      row.with_cell(header: true, text: 'Placeholder 2')
      row.with_cell(text: '1999-2002')
      row.with_cell(text: 'Status')
    end

    body.with_row do |row|
      row.with_cell(header: true, text: 'Placeholder 3')
      row.with_cell(text: '2002-2006')
    end

    body.with_row do |row|
      row.with_cell(header: true, text: 'Placeholder 4')
      row.with_cell(text: '2006-2010')
    end
  end
end %>

<%= govuk_button_link_to('Create new key', 'api_keys/create', secondary: true) %>

<h2 class="govuk-heading-m">If you need help</h2>
<p class="govuk-body">If you have any further queries relating to the developer hub contact:
  <%= mail_to 'hmrc-trade-tariff-support-g@digital.hmrc.gov.uk', 'hmrc-trade-tariff-support-g@digital.hmrc.gov.uk', class: 'govuk-link' %>.
</p>
