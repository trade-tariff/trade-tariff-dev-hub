<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= govuk_panel(title_text: "Your API Key has been created successfully") %>
    <h2 class="govuk-heading-l">What happens next</h2>
    <p class="govuk-body">Use the API key to access the Commodity Code Identification Tool. Use this API in the <strong>X-Api-Key</strong> header of any calls you make.</p>
    <%= govuk_warning_text(text: "You must copy this key to somewhere safe. You will not be able to view this API key again once you leave this page.") %>
    <div class="govuk-inset-text">
      <strong>API Key</strong>
      <br>
      <code class="govuk-code"><%= @api_key %></code>
    </div>
    <%= govuk_button_to('Copy to clipboard', '#', secondary: true) %>
    <%= govuk_link_to('Back to dashboard', '/dashboard') %>
  </div>
</div>
